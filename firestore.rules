rules_version = '2';
// REGRAS DE ARRANQUE (bootstrap)- permitem correr o /setup na primeira vez.
// Não há lado público: tudo exige autenticação.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    match /{col}/{id} {
      allow read, write: if isSignedIn();
    }
  }
}
